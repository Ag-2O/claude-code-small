{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Edit",
      "Write",
      "Skill",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(gh pr merge *)"
    ],
    "deny": [
      "Bash(curl *)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Write(**/.env)",
      "Bash(python *)",
      "Bash(rm -rf *)"
    ],
    "defaultMode": "acceptEdits"
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/scripts/run_python_hook.sh .claude/scripts/recorder/record_messages.py",
            "statusMessage": "セッション履歴を記録中..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/scripts/run_python_hook.sh .claude/scripts/formatters/format_python.py",
            "statusMessage": "Pythonコードをフォーマット中..."
          },
          {
            "type": "command",
            "command": "bash .claude/scripts/run_python_hook.sh .claude/scripts/formatters/format_markdown.py",
            "statusMessage": "Markdownをフォーマット中..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/scripts/run_python_hook.sh .claude/scripts/recorder/record_messages.py",
            "statusMessage": "セッション履歴を記録中..."
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/scripts/run_python_hook.sh .claude/scripts/recorder/record_messages.py",
            "statusMessage": "セッション履歴を記録中..."
          }
        ]
      }
    ]
  }
}
